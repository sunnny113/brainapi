# =========================
# BrainAPI Environment File
# =========================
# Copy this file to .env and fill in values for your environment.
# NEVER commit real secrets.

# -------------------------
# Runtime / Environment
# -------------------------
# App runtime environment: development | staging | production
ENVIRONMENT=development

# Public base URL used in links/emails/docs metadata
PUBLIC_BASE_URL=http://localhost:8000

# Provider selection: auto, openai, anthropic, together, groq, gemini, ollama, mock
PROVIDER=auto

# Provider fallback order used when PROVIDER=auto
PROVIDER_FALLBACK_ORDER=local,ollama,groq,gemini,huggingface,pollinations,together,openai

# JSON routing profile for the unified AI gateway
ROUTING_CONFIG_PATH=brainapi.config.json


# -------------------------
# Security / Auth
# -------------------------
# Require API key for protected endpoints
REQUIRE_API_KEY=true

# Optional static API keys (comma-separated) for bootstrap access
API_KEYS=replace-with-strong-key-1,replace-with-strong-key-2

# Admin key for /api/v1/admin/* endpoints
ADMIN_API_KEY=replace-with-strong-admin-key

# Session/JWT signing secret (REQUIRED in production; minimum 32 chars)
AUTH_TOKEN_SECRET=replace-with-strong-random-secret-at-least-32-chars

# Default per-key request rate limit (requests/minute)
RATE_LIMIT_PER_MINUTE=60

# Hard cap on text tokens accepted in a single AI request
MAX_TOKENS_PER_REQUEST=4000

# Hard cap on estimated text tokens accepted per key per minute
MAX_TOKENS_PER_MINUTE=40000

# Public unauthenticated paths (comma-separated)
PUBLIC_PATHS=/,/ui,/health,/docs,/openapi.json,/redoc,/robots.txt,/sitemap.xml,/api/v1/billing/razorpay/webhook,/api/v1/public/plans,/api/v1/public/reviews,/api/v1/public/signup-trial,/api/v1/auth/signup,/api/v1/auth/login,/api/v1/auth/request-reset,/api/v1/auth/reset-password


# -------------------------
# Database / Storage
# -------------------------
# SQLAlchemy database URL
DATABASE_URL=postgresql+psycopg://postgres:replace-with-db-password@localhost:5432/brainapi

# Auto-create tables on startup (recommended true only for local/dev)
AUTO_CREATE_TABLES=true

# Redis URL for distributed rate limiting and cache (blank disables Redis limiter)
REDIS_URL=redis://localhost:6379/0

# Enable usage event metering
ENABLE_USAGE_METERING=true


# -------------------------
# CORS / API Gateway
# -------------------------
# Allowed browser origins (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8000

# Allowed HTTP methods for CORS preflight
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Allowed request headers for CORS preflight
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-API-Key


# -------------------------
# AI Provider: OpenAI
# -------------------------
# OpenAI API key
OPENAI_API_KEY=replace-with-openai-api-key

# OpenAI text model
OPENAI_TEXT_MODEL=gpt-4.1-mini

# OpenAI image model
OPENAI_IMAGE_MODEL=gpt-image-1

# OpenAI transcription model
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe


# -------------------------
# AI Provider: Anthropic
# -------------------------
# Anthropic API key
ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# Anthropic API base URL
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Anthropic text model
ANTHROPIC_TEXT_MODEL=claude-3-5-sonnet-latest


# -------------------------
# AI Provider: Together
# -------------------------
# Together API key
TOGETHER_API_KEY=replace-with-together-api-key

# Together API base URL
TOGETHER_BASE_URL=https://api.together.xyz/v1

# Together text model
TOGETHER_TEXT_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free

# Together image model
TOGETHER_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell-Free

# Together transcription model
TOGETHER_TRANSCRIPTION_MODEL=openai/whisper-large-v3


# -------------------------
# AI Provider: Groq
# -------------------------
# Groq API key
GROQ_API_KEY=replace-with-groq-api-key

# Groq API base URL
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Groq text model
GROQ_TEXT_MODEL=llama-3.1-8b-instant


# -------------------------
# AI Provider: Gemini
# -------------------------
# Gemini API key
GEMINI_API_KEY=replace-with-gemini-api-key

# Gemini API base URL
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Gemini text model
GEMINI_TEXT_MODEL=gemini-1.5-flash


# -------------------------
# AI Provider: Ollama (local)
# -------------------------
# Ollama base URL
OLLAMA_BASE_URL=http://localhost:11434

# Ollama text model
OLLAMA_TEXT_MODEL=llama3.2:3b


# -------------------------
# Automation / Webhooks
# -------------------------
# Comma-separated allowlist of automation target hosts (blank = unrestricted + internal checks)
AUTOMATION_ALLOWED_HOSTS=

# Allow private/internal IP webhook targets (should remain false in production)
ALLOW_PRIVATE_WEBHOOK_TARGETS=false

# Maximum automation steps per run
AUTOMATION_MAX_STEPS=20

# Default timeout for outbound webhook/API calls (seconds)
DEFAULT_WEBHOOK_TIMEOUT_SECONDS=15


# -------------------------
# Upload Constraints
# -------------------------
# Maximum uploaded audio file size in MB
MAX_UPLOAD_FILE_SIZE_MB=25

# Allowed uploaded audio MIME types (comma-separated)
ALLOWED_AUDIO_FILE_TYPES=audio/mpeg,audio/wav,audio/ogg,audio/flac,audio/m4a,audio/x-m4a


# -------------------------
# Billing (Razorpay)
# -------------------------
# Razorpay key id
RAZORPAY_KEY_ID=rzp_test_replace_me

# Razorpay key secret
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret

# Razorpay webhook signature secret
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret

# Default paid plan amount in INR
DEFAULT_PLAN_AMOUNT_INR=999

# Default paid plan display name
DEFAULT_PLAN_NAME=BrainAPI Pro


# -------------------------
# Trial / Signup Defaults
# -------------------------
# Toggle public trial signup
TRIAL_SIGNUP_ENABLED=true

# Trial duration in days
TRIAL_DEFAULT_DAYS=7

# Trial default rate limit (requests/minute)
TRIAL_DEFAULT_RATE_LIMIT_PER_MINUTE=60


# -------------------------
# Email / SMTP
# -------------------------
# Public support inbox shown in onboarding, docs, and status pages
SUPPORT_EMAIL=brainapisupport@gmail.com

# Founder name shown on public pages
FOUNDER_NAME=BrainAPI founder

# SMTP host
SMTP_HOST=smtp.brainapi.site

# SMTP port
SMTP_PORT=587

# SMTP username
SMTP_USERNAME=replace-with-smtp-username

# SMTP password
SMTP_PASSWORD=replace-with-smtp-password

# Use STARTTLS/TLS for SMTP
SMTP_USE_TLS=true

# From email address
EMAIL_FROM_ADDRESS=noreply@brainapi.site

# From display name
EMAIL_FROM_NAME=BrainAPI

# Reply-to email address
EMAIL_REPLY_TO=support@brainapi.site

# Block obviously fake recipient domains
BLOCKED_EMAIL_DOMAINS=example.com,test.com,fake.com

# Skip actual delivery outside production
SKIP_EMAIL_IN_DEVELOPMENT=true


# -------------------------
# Password Reset
# -------------------------
# Password reset token TTL in minutes
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
